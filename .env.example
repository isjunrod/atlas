# Server
PORT=8080
NODE_ENV=production
LOG_LEVEL=info

# WhatsApp Cloud API (Meta)
WHATSAPP_PHONE_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_long_lived_access_token
WHATSAPP_VERIFY_TOKEN=a_random_string_you_pick
WHATSAPP_BUSINESS_ACCOUNT_ID=your_waba_id

# OpenAI
OPENAI_API_KEY=sk-proj-...
OPENAI_CHAT_MODEL=gpt-4.1-mini
ATLAS_VECTOR_STORE_ID=vs_will_be_set_after_ingest

# PostgreSQL (Aiven o el que uses)
DATABASE_URL=postgres://user:pass@host:port/atlas?sslmode=require

# Escalamiento via email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=atlas-bot@your-domain.com
SMTP_PASS=your_app_password
ESCALATION_EMAIL_TO=director.educacion@adschool.agency
ESCALATION_EMAIL_FROM=ATLAS <atlas-bot@your-domain.com>

# Admin panel
ADMIN_USER=karen
ADMIN_PASS=change_me_please
ADMIN_SESSION_SECRET=long_random_string

# Feature flags
ATLAS_BACKEND_MODEL=gpt-4.1-mini
ATLAS_FALLBACK_MODEL=gpt-4o-mini
CONTEXT_RECENT_TURNS=8
